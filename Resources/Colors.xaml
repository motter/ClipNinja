<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Sky / Stage colors -->
    <Color x:Key="SkyTopColor">#FF8DA9B8</Color>
    <Color x:Key="SkyHorizonColor">#FFDECDA2</Color>

    <!-- Desert hills -->
    <Color x:Key="MesaHiColor">#FFE0B255</Color>
    <Color x:Key="MesaMidColor">#FFB57536</Color>
    <Color x:Key="MesaLoColor">#FF6B5429</Color>

    <!-- Sun -->
    <Color x:Key="SunColor">#FFF4B844</Color>
    <Color x:Key="SunGlowColor">#FFE59A2A</Color>

    <!-- UI Panel & Slot colors -->
    <Color x:Key="PanelColor">#FF3A2E22</Color>     <!-- header / footer bar -->
    <Color x:Key="BgColor">#FF2A2128</Color>        <!-- slot row default -->
    <Color x:Key="ActiveColor">#FF8B5A2B</Color>    <!-- active slot bg -->
    <Color x:Key="BorderColor">#FF4A3D2E</Color>    <!-- subtle borders & dim arrows -->
    <Color x:Key="TextColor">#FFF4E8D0</Color>      <!-- main text cream -->
    <Color x:Key="SubTextColor">#FFB8A687</Color>   <!-- muted tan -->
    <Color x:Key="AccentColor">#FFE59A2A</Color>    <!-- amber accent -->

    <!-- Ninja palette -->
    <Color x:Key="NinjaColor">#FF3D4046</Color>
    <Color x:Key="NinjaDarkColor">#FF1F2228</Color>
    <Color x:Key="NinjaHiColor">#FF5A5E66</Color>
    <Color x:Key="NinjaSkinColor">#FFC9A98A</Color>

    <!-- SolidColorBrush wrappers (most controls use brushes, not raw colors) -->
    <SolidColorBrush x:Key="PanelBrush" Color="{StaticResource PanelColor}" />
    <SolidColorBrush x:Key="BgBrush" Color="{StaticResource BgColor}" />
    <SolidColorBrush x:Key="ActiveBrush" Color="{StaticResource ActiveColor}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}" />
    <SolidColorBrush x:Key="SubTextBrush" Color="{StaticResource SubTextColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="SunBrush" Color="{StaticResource SunColor}" />
    <SolidColorBrush x:Key="SunGlowBrush" Color="{StaticResource SunGlowColor}" />

    <!-- Stage scene brushes -->
    <SolidColorBrush x:Key="MesaHiBrush" Color="{StaticResource MesaHiColor}" />
    <SolidColorBrush x:Key="MesaMidBrush" Color="{StaticResource MesaMidColor}" />
    <SolidColorBrush x:Key="MesaLoBrush" Color="{StaticResource MesaLoColor}" />
    <SolidColorBrush x:Key="NinjaBrush" Color="{StaticResource NinjaColor}" />
    <SolidColorBrush x:Key="NinjaDarkBrush" Color="{StaticResource NinjaDarkColor}" />
    <SolidColorBrush x:Key="NinjaHiBrush" Color="{StaticResource NinjaHiColor}" />
    <SolidColorBrush x:Key="NinjaSkinBrush" Color="{StaticResource NinjaSkinColor}" />

</ResourceDictionary>
