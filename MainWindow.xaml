<Window x:Class="ClipNinjaV2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        xmlns:vm="clr-namespace:ClipNinjaV2.ViewModels"
        xmlns:m="clr-namespace:ClipNinjaV2.Models"
        Title="ClipNinja"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="True"
        Width="360" Height="920"
        MinWidth="320" MinHeight="500"
        Icon="Resources/ninja.ico"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        PreviewKeyDown="OnWindow_PreviewKeyDown">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- DataTemplate for one slot row -->
        <DataTemplate x:Key="SlotItemTemplate" DataType="{x:Type m:ClipSlot}">
            <StackPanel>
                <Border x:Name="RowBorder"
                    Background="{StaticResource BgBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="6,4"
                    Height="40"
                    AllowDrop="True"
                    MouseLeftButtonDown="OnSlotRow_MouseLeftButtonDown"
                    MouseLeftButtonUp="OnSlotRow_MouseLeftButtonUp"
                    MouseMove="OnSlotRow_MouseMove"
                    DragOver="OnSlotRow_DragOver"
                    DragLeave="OnSlotRow_DragLeave"
                    Drop="OnSlotRow_Drop">
                <Border.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="📌 Pin / Unpin"      Click="OnSlotMenu_TogglePin" />
                        <MenuItem Header="🏷️ Set nickname…"   Click="OnSlotMenu_SetNickname" />
                        <Separator />
                        <MenuItem Header="⬆️ Move up"          Click="OnSlotMenu_MoveUp" />
                        <MenuItem Header="⬇️ Move down"        Click="OnSlotMenu_MoveDown" />
                        <Separator />
                        <MenuItem Header="✏️ Edit text…"      Click="OnSlotMenu_EditText" />
                        <MenuItem Header="📋 Copy as plain text" Click="OnSlotMenu_CopyPlainText"
                                  ToolTip="Put just the unformatted text on the clipboard — strips fonts, colors, and links" />
                        <MenuItem Header="🖍️ Annotate image…" Click="OnSlotMenu_AnnotateImage" />
                        <MenuItem Header="💾 Save image to folder" Click="OnSlotMenu_SaveImage" />
                        <MenuItem Header="🗑️ Remove this item" Click="OnSlotMenu_Clear" />
                    </ContextMenu>
                </Border.ContextMenu>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="28" />   <!-- index badge -->
                        <ColumnDefinition Width="36" />   <!-- thumbnail -->
                        <ColumnDefinition Width="*" />    <!-- text -->
                        <ColumnDefinition Width="22" />   <!-- pin lock indicator -->
                        <ColumnDefinition Width="22" />   <!-- arrows -->
                        <ColumnDefinition Width="26" />   <!-- eraser -->
                    </Grid.ColumnDefinitions>

                    <!-- Index badge -->
                    <Border Style="{StaticResource SlotIndexBadgeStyle}"
                            x:Name="IndexBadge"
                            Grid.Column="0">
                        <TextBlock Text="{Binding Index}"
                                   x:Name="IndexText"
                                   Foreground="{StaticResource SubTextBrush}"
                                   FontFamily="Consolas"
                                   FontWeight="Bold"
                                   FontSize="11"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>

                    <!-- Image thumbnail (only visible if slot has image).
                         For GIF slots, a small "GIF" badge overlays the
                         bottom-right corner so the user can tell which slots
                         are animated. We don't animate the thumbnail itself
                         (WPF doesn't natively, and adding a frame-cycling
                         timer per slot is not worth the complexity). -->
                    <Border Grid.Column="1"
                            Width="32" Height="32"
                            Background="{StaticResource BorderBrush}"
                            CornerRadius="2"
                            Visibility="{Binding HasImage, Converter={StaticResource BoolToVis}}"
                            MouseEnter="OnSlotRow_MouseEnter"
                            MouseLeave="OnSlotRow_MouseLeave">
                        <Grid>
                            <Image Source="{Binding ThumbnailSource}"
                                   Width="32" Height="32"
                                   Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="LowQuality"
                                   UseLayoutRounding="True"
                                   SnapsToDevicePixels="True" />
                            <!-- GIF badge — small pill at bottom-right. Visible
                                 only when the captured image came from a .gif
                                 source (detected via CF_HDROP at capture time). -->
                            <Border Visibility="{Binding HasGif, Converter={StaticResource BoolToVis}}"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Bottom"
                                    Background="#FFE54545"
                                    CornerRadius="2"
                                    Padding="2,0"
                                    Margin="0,0,1,1">
                                <TextBlock Text="GIF"
                                           FontFamily="Arial Black, Impact, sans-serif"
                                           FontSize="7"
                                           FontWeight="Bold"
                                           Foreground="White" />
                            </Border>
                            <!-- Annotate badge — pencil at top-right of the
                                 thumbnail. Click opens the annotation editor
                                 directly (the right-click menu item still
                                 exists too). Handled=true in the handler so
                                 the click doesn't ALSO load the slot. -->
                            <Border HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Background="#CC2A2620"
                                    CornerRadius="2"
                                    Padding="2,0,2,1"
                                    Margin="0,1,1,0"
                                    Cursor="Hand"
                                    ToolTip="Annotate this image"
                                    MouseLeftButtonDown="OnSlotPencil_Click">
                                <TextBlock Text="✏️" FontSize="8" />
                            </Border>
                            <!-- Quick-save badge — 💾 at top-LEFT. One click
                                 writes a timestamped PNG to the quick-save
                                 folder (falls back to Save-as if unset), so
                                 you can grab a file to upload without the
                                 right-click menu. Handled=true so it doesn't
                                 load the slot. -->
                            <Border HorizontalAlignment="Left"
                                    VerticalAlignment="Top"
                                    Background="#CC2A2620"
                                    CornerRadius="2"
                                    Padding="2,0,2,1"
                                    Margin="1,1,0,0"
                                    Cursor="Hand"
                                    ToolTip="Quick-save this image to a file"
                                    MouseLeftButtonDown="OnSlotQuickSave_Click">
                                <TextBlock Text="💾" FontSize="8" />
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Spreadsheet icon (visible if slot holds tabular data) -->
                    <Border Grid.Column="1"
                            Width="32" Height="32"
                            Background="#FFA8CBA0"
                            CornerRadius="2"
                            Visibility="{Binding HasSpreadsheet, Converter={StaticResource BoolToVis}}"
                            ToolTip="Spreadsheet / table data"
                            MouseEnter="OnSlotRow_MouseEnter"
                            MouseLeave="OnSlotRow_MouseLeave">
                        <!-- Vector grid icon — rows + columns to suggest a table.
                             Lines use a darker green that reads against the
                             muted A8CBA0 background. -->
                        <Viewbox Margin="4">
                            <Canvas Width="24" Height="24">
                                <!-- Outer rectangle border -->
                                <Rectangle Canvas.Left="1" Canvas.Top="2"
                                           Width="22" Height="20"
                                           Stroke="#FF305A2A" StrokeThickness="1.5"
                                           Fill="Transparent" RadiusX="1" RadiusY="1" />
                                <!-- Header row band -->
                                <Rectangle Canvas.Left="1" Canvas.Top="2"
                                           Width="22" Height="5"
                                           Fill="#FF305A2A" Opacity="0.85" RadiusX="1" RadiusY="1" />
                                <!-- Vertical column dividers -->
                                <Line X1="9" Y1="2" X2="9" Y2="22"
                                      Stroke="#FF305A2A" StrokeThickness="1" />
                                <Line X1="16" Y1="2" X2="16" Y2="22"
                                      Stroke="#FF305A2A" StrokeThickness="1" />
                                <!-- Horizontal row dividers -->
                                <Line X1="1" Y1="12" X2="23" Y2="12"
                                      Stroke="#FF305A2A" StrokeThickness="1" />
                                <Line X1="1" Y1="17" X2="23" Y2="17"
                                      Stroke="#FF305A2A" StrokeThickness="1" />
                            </Canvas>
                        </Viewbox>
                    </Border>

                    <!-- Plain-text icon (visible for non-spreadsheet text slots).
                         A document-page silhouette with a folded corner and a
                         few text lines. Uses our accent palette so it reads as
                         "text content" without competing with the Excel icon. -->
                    <Border Grid.Column="1"
                            Width="32" Height="32"
                            Background="{StaticResource AccentBrush}"
                            CornerRadius="2"
                            Visibility="{Binding HasPlainText, Converter={StaticResource BoolToVis}}"
                            ToolTip="Text"
                            MouseEnter="OnSlotRow_MouseEnter"
                            MouseLeave="OnSlotRow_MouseLeave">
                        <Viewbox Margin="5">
                            <Canvas Width="22" Height="22">
                                <!-- Page silhouette with folded top-right corner.
                                     Drawn as a polygon: top-left → fold-start → fold-corner-cutout → bottom-right → bottom-left -->
                                <Path Fill="{StaticResource PanelBrush}"
                                      Stroke="{StaticResource PanelBrush}"
                                      StrokeThickness="0.6"
                                      StrokeLineJoin="Round"
                                      Data="M 3,2 L 14,2 L 20,8 L 20,20 L 3,20 Z" />
                                <!-- Folded corner triangle (slightly darker for depth) -->
                                <Path Fill="{StaticResource BgBrush}"
                                      Stroke="{StaticResource PanelBrush}"
                                      StrokeThickness="0.5"
                                      Data="M 14,2 L 20,8 L 14,8 Z" />
                                <!-- Three "text" lines on the page -->
                                <Line X1="6" Y1="11" X2="17" Y2="11"
                                      Stroke="{StaticResource AccentBrush}" StrokeThickness="1.4"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                <Line X1="6" Y1="14" X2="17" Y2="14"
                                      Stroke="{StaticResource AccentBrush}" StrokeThickness="1.4"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                <Line X1="6" Y1="17" X2="13" Y2="17"
                                      Stroke="{StaticResource AccentBrush}" StrokeThickness="1.4"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                            </Canvas>
                        </Viewbox>
                    </Border>

                    <!-- URL thumbnail — visible when the slot holds a single URL.
                         A pair of interlinked chain-link shapes drawn on a blue
                         background. Reads instantly as "link" without competing
                         with the spreadsheet (green) and text (ochre) icons. -->
                    <!-- URL thumbnail — visible when the slot holds a single URL.
                         Dusty sky blue background (matches the upper sky color
                         of the ninja stage). Chain-link drawn in deep navy so
                         it reads clearly on the soft background. -->
                    <Border Grid.Column="1"
                            Width="32" Height="32"
                            Background="#FF99AEB5"
                            CornerRadius="2"
                            Visibility="{Binding HasUrl, Converter={StaticResource BoolToVis}}"
                            ToolTip="Link / URL"
                            MouseEnter="OnSlotRow_MouseEnter"
                            MouseLeave="OnSlotRow_MouseLeave">
                        <Viewbox Margin="5">
                            <Canvas Width="22" Height="22">
                                <!-- Back link (top-left → bottom-right diagonal) -->
                                <Path Stroke="#FF1B3A55" StrokeThickness="2.2"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Fill="Transparent"
                                      Data="M 4,10 L 7.5,6.5 A 2.5,2.5 0 0 1 11,6.5 L 11.5,7 A 2.5,2.5 0 0 1 11.5,10.5 L 9.5,12.5" />
                                <!-- Front link (bottom-left → top-right diagonal) -->
                                <Path Stroke="#FF1B3A55" StrokeThickness="2.2"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Fill="Transparent"
                                      Data="M 18,12 L 14.5,15.5 A 2.5,2.5 0 0 1 11,15.5 L 10.5,15 A 2.5,2.5 0 0 1 10.5,11.5 L 12.5,9.5" />
                                <!-- Tiny highlight to suggest "this is clickable" -->
                                <Ellipse Canvas.Left="9.5" Canvas.Top="9.5"
                                         Width="3" Height="3" Fill="White" Opacity="0.55" />
                            </Canvas>
                        </Viewbox>
                    </Border>

                    <!-- Slot display text -->
                    <TextBlock Grid.Column="2"
                               x:Name="SlotText"
                               Text="{Binding DisplayText}"
                               Style="{StaticResource SlotTextStyle}"
                               Margin="6,0,28,0" />

                    <!-- Link-count badge — small pill at right edge of text column
                         showing "🔗 N" when the slot's content has embedded
                         hyperlinks (parsed from CF_HTML at capture time). Shown
                         for slots from emails/web pages where the original copy
                         included formatted links. Tooltip shows which links. -->
                    <Border Grid.Column="2"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0,0,4,0"
                            Padding="4,1"
                            CornerRadius="3"
                            Background="#FF1B3A55"
                            Visibility="{Binding HasLinks, Converter={StaticResource BoolToVis}}"
                            ToolTip="This slot has embedded hyperlinks — hover the text to see them in the preview popup">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔗"
                                       Foreground="White"
                                       FontSize="9"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{Binding LinkCount}"
                                       Foreground="White"
                                       FontSize="9"
                                       FontWeight="Bold"
                                       Margin="2,0,0,0"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <!-- Pin lock indicator. Always visible: shows OPEN padlock
                         when unpinned (clickable to lock), CLOSED padlock when
                         pinned (clickable to unlock). The Border captures clicks
                         across the full cell so the hit zone is much bigger
                         than the tiny icon. -->
                    <Border x:Name="LockHitZone"
                            Grid.Column="3"
                            Background="Transparent"
                            Cursor="Hand"
                            ToolTip="Click to pin / unpin this slot"
                            MouseLeftButtonDown="OnLock_Click"
                            MouseLeftButtonUp="OnLock_MouseUp"
                            TextElement.Foreground="{StaticResource BorderBrush}">
                        <!-- Visible when the slot has content (so you can pin/unpin),
                             AND also visible on empty-but-pinned slots so that
                             orphan pins can be cleared. Hidden only when the slot
                             is truly empty AND unpinned (the nothing-to-do case). -->
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsEmpty}" Value="True" />
                                            <Condition Binding="{Binding IsPinned}" Value="False" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Viewbox Width="11" Height="13"
                                 VerticalAlignment="Center"
                                 HorizontalAlignment="Center">
                            <Canvas Width="16" Height="18">
                                <!-- Shackle: shape changes based on IsPinned.
                                     Open (default) = right end lifted up & right.
                                     Closed (pinned) = complete arch back to body. -->
                                <Path x:Name="LockShackle"
                                      Stroke="{Binding Path=(TextElement.Foreground), RelativeSource={RelativeSource AncestorType=Border}}"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Fill="Transparent">
                                    <Path.Style>
                                        <Style TargetType="Path">
                                            <!-- Default: OPEN — right end pops up and out -->
                                            <Setter Property="Data"
                                                    Value="M 4,8 L 4,5 A 4,4 0 0 1 12,5 L 14,2" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsPinned}" Value="True">
                                                    <!-- CLOSED — full arch, both ends at body -->
                                                    <Setter Property="Data"
                                                            Value="M 4,8 L 4,5 A 4,4 0 0 1 12,5 L 12,8" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Path.Style>
                                </Path>
                                <!-- Lock body (same in both states) -->
                                <Path Fill="{Binding Path=(TextElement.Foreground), RelativeSource={RelativeSource AncestorType=Border}}"
                                      Data="M 2,8 L 14,8 A 1.5,1.5 0 0 1 15.5,9.5 L 15.5,16 A 1.5,1.5 0 0 1 14,17.5 L 2,17.5 A 1.5,1.5 0 0 1 0.5,16 L 0.5,9.5 A 1.5,1.5 0 0 1 2,8 Z" />
                                <!-- Keyhole -->
                                <Ellipse Canvas.Left="6.5" Canvas.Top="11"
                                         Width="3" Height="3"
                                         Fill="{StaticResource BgBrush}" />
                            </Canvas>
                        </Viewbox>
                    </Border>

                    <!-- Up/Down reorder arrows. -->
                    <StackPanel Grid.Column="4"
                                Orientation="Vertical"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center">
                        <TextBlock x:Name="UpArrow"
                                   Text="▲"
                                   FontFamily="Segoe UI Symbol"
                                   FontSize="9"
                                   Cursor="Hand"
                                   Foreground="{StaticResource BorderBrush}"
                                   MouseLeftButtonDown="OnArrowUp_Click"
                                   MouseLeftButtonUp="OnIconBtn_MouseUp" />
                        <TextBlock x:Name="DownArrow"
                                   Text="▼"
                                   FontFamily="Segoe UI Symbol"
                                   FontSize="9"
                                   Cursor="Hand"
                                   Foreground="{StaticResource BorderBrush}"
                                   Margin="0,2,0,0"
                                   MouseLeftButtonDown="OnArrowDown_Click"
                                   MouseLeftButtonUp="OnIconBtn_MouseUp" />
                    </StackPanel>

                    <!-- Eraser button (Power BI-style angled eraser) to clear this slot.
                         The wrapping Border catches clicks across the full cell. -->
                    <Border x:Name="EraserBtn"
                            Grid.Column="5"
                            Background="Transparent"
                            Cursor="Hand"
                            ToolTip="Clear this slot"
                            MouseLeftButtonDown="OnEraser_Click"
                            MouseLeftButtonUp="OnIconBtn_MouseUp"
                            TextElement.Foreground="{StaticResource BorderBrush}">
                        <Viewbox Width="14" Height="14"
                                 VerticalAlignment="Center"
                                 HorizontalAlignment="Center">
                            <Canvas Width="22" Height="22">
                                <!-- Eraser body (the angled rectangular eraser, outlined) -->
                                <Path Stroke="{Binding Path=(TextElement.Foreground), RelativeSource={RelativeSource AncestorType=Border}}"
                                      StrokeThickness="1.5"
                                      StrokeLineJoin="Round"
                                      Fill="Transparent"
                                      Data="M 4,15 L 13,4 L 19,8 L 11,18 Z" />
                                <!-- Tip (darker portion that does the erasing — filled, semi-opaque) -->
                                <Path Stroke="{Binding Path=(TextElement.Foreground), RelativeSource={RelativeSource AncestorType=Border}}"
                                      StrokeThickness="1.5"
                                      StrokeLineJoin="Round"
                                      Fill="{Binding Path=(TextElement.Foreground), RelativeSource={RelativeSource AncestorType=Border}}"
                                      Opacity="0.55"
                                      Data="M 7,18 L 11,18 L 19,8 L 16,5 Z" />
                                <!-- Three small "dust marks" trailing -->
                                <Path Stroke="{Binding Path=(TextElement.Foreground), RelativeSource={RelativeSource AncestorType=Border}}"
                                      StrokeThickness="1.2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Data="M 1,19 L 4,18 M 0,16 L 3,15.5 M 1,21.5 L 4,20.5" />
                            </Canvas>
                        </Viewbox>
                    </Border>
                </Grid>
            </Border>
            </StackPanel>
            <DataTemplate.Triggers>
                <!-- Active slot — amber background + bright text/icons -->
                <DataTrigger Binding="{Binding IsActive}" Value="True">
                    <Setter TargetName="RowBorder" Property="Background" Value="{StaticResource ActiveBrush}" />
                    <Setter TargetName="IndexBadge" Property="Background" Value="{StaticResource AccentBrush}" />
                    <Setter TargetName="IndexText" Property="Foreground" Value="{StaticResource TextBrush}" />
                    <Setter TargetName="SlotText" Property="Foreground" Value="{StaticResource TextBrush}" />
                    <Setter TargetName="UpArrow" Property="Foreground" Value="{StaticResource TextBrush}" />
                    <Setter TargetName="DownArrow" Property="Foreground" Value="{StaticResource TextBrush}" />
                    <Setter TargetName="LockHitZone" Property="TextElement.Foreground" Value="{StaticResource TextBrush}" />
                    <Setter TargetName="EraserBtn" Property="TextElement.Foreground" Value="{StaticResource TextBrush}" />
                </DataTrigger>
                <!-- Pinned slot — yellow index badge -->
                <DataTrigger Binding="{Binding IsPinned}" Value="True">
                    <Setter TargetName="IndexBadge" Property="Background" Value="{StaticResource SunGlowBrush}" />
                    <Setter TargetName="IndexText" Property="Foreground" Value="{StaticResource PanelBrush}" />
                </DataTrigger>
                <!-- Drop target during drag — accent border shows where it will land -->
                <DataTrigger Binding="{Binding IsDropTarget}" Value="True">
                    <Setter TargetName="RowBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                    <Setter TargetName="RowBorder" Property="BorderThickness" Value="0,2,0,2" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <!-- Tray icon (no visual size) -->
        <tb:TaskbarIcon x:Name="Tray"
                        IconSource="Resources/ninja.ico"
                        ToolTipText="ClipNinja"
                        NoLeftClickDelay="True"
                        TrayLeftMouseUp="OnTrayShow_Click">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu Opened="OnTrayContextMenu_Opened">
                    <MenuItem Header="Show / Hide ClipNinja" Click="OnTrayShow_Click" />
                    <Separator />
                    <MenuItem x:Name="TrayLaunchOnStartupItem"
                              Header="Launch on Windows startup"
                              IsCheckable="True"
                              Click="OnTrayLaunchOnStartup_Click" />
                    <MenuItem x:Name="TrayImageBorderItem"
                              Header="Black border on screenshots: ON"
                              Click="OnTrayImageBorder_Click" />
                    <Separator />
                    <MenuItem x:Name="TrayCaptureRegionItem" Header="📷 Capture region"      Click="OnTrayCaptureRegion_Click" InputGestureText="Ctrl+Shift+C" />
                    <!-- Children (All monitors / Monitor 1 / 2 / …) are rebuilt
                         in OnTrayContextMenu_Opened so hot-plugged displays
                         show up without a restart. -->
                    <MenuItem x:Name="TrayCaptureFullItem"   Header="🖥️ Capture full screen" />
                    <Separator />
                    <MenuItem Header="Settings…"  Click="OnTraySettings_Click" />
                    <MenuItem Header="⬆️ Check for updates…" Click="OnTrayCheckUpdates_Click" />
                    <MenuItem Header="Clear everything" Click="OnTrayClearAll_Click" />
                    <MenuItem Header="Open trace log…" Click="OnTrayOpenTrace_Click" />
                    <MenuItem Header="Open image-debug log…" Click="OnTrayOpenImageDebug_Click" />
                    <Separator />
                    <MenuItem Header="Exit" Click="OnTrayExit_Click" />
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>

        <!-- Main rounded container -->
        <Border CornerRadius="14"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="42" />     <!-- Header bar -->
                    <RowDefinition Height="160" />    <!-- Ninja stage -->
                    <RowDefinition Height="*" />      <!-- Slot list -->
                    <RowDefinition Height="Auto" />   <!-- Footer -->
                </Grid.RowDefinitions>

                <!-- Header (drag region) -->
                <Border Grid.Row="0"
                        Background="{StaticResource PanelBrush}"
                        MouseLeftButtonDown="OnHeader_DragStart"
                        CornerRadius="14,14,0,0">
                    <Grid>
                        <!-- Version sits to the LEFT of the name. The title
                             block is centered while the window buttons are
                             right-aligned ON TOP of it, so anything trailing
                             the name gets covered once the button row grows
                             (adding 🔍 in v2.9.1 buried the version). Left of
                             the name there's nothing to collide with. -->
                        <TextBlock Style="{StaticResource HeaderTextStyle}">
                            <Run Text="v2.10.0 "
                                 FontSize="9"
                                 Foreground="{StaticResource SubTextBrush}"
                                 FontWeight="Normal" />
                            <Run Text="🥷 ClipNinja" />
                        </TextBlock>
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Margin="0,0,8,0">
                            <!-- Search + type filter. The search bar (with the
                                 icon type-filter row) was Ctrl+F only, which
                                 made the whole filtering feature invisible —
                                 this button is its front door. -->
                            <Button x:Name="SearchButton"
                                    Style="{StaticResource WinChromeButtonStyle}"
                                    Content="🔍"
                                    Click="OnSearchButton_Click"
                                    ToolTip="Search &amp; filter by type (Ctrl+F)" />
                            <!-- Screen capture — drag-select a region, Greenshot-
                                 style. Ctrl+PrintScreen for instant full screen. -->
                            <Button x:Name="CaptureButton"
                                    Style="{StaticResource WinChromeButtonStyle}"
                                    Content="📷"
                                    Click="OnCaptureButton_Click"
                                    ToolTip="Capture a screen region (Ctrl+Shift+C) • Ctrl+Shift+Z = full screen" />
                            <!-- Settings — same dialog as the tray menu item,
                                 but discoverable in the app itself. -->
                            <Button x:Name="SettingsButton"
                                    Style="{StaticResource WinChromeButtonStyle}"
                                    Content="⚙"
                                    Click="OnSettingsButton_Click"
                                    ToolTip="Settings" />
                            <!-- Border-on-screenshots quick toggle. Shows
                                 filled/outlined frame glyph by state. Only
                                 affects FUTURE captures — the tooltip says
                                 so because that's a common mental-model
                                 mismatch. -->
                            <Button x:Name="BorderToggleButton"
                                    Style="{StaticResource WinChromeButtonStyle}"
                                    Content="🖼"
                                    Click="OnBorderToggle_Click"
                                    ToolTip="Black border on new screenshots: ON (click to turn off)" />
                            <Button Style="{StaticResource WinChromeButtonStyle}"
                                    Content="—"
                                    Click="OnMinimize_Click" />
                            <Button Style="{StaticResource WinChromeButtonStyle}"
                                    Content="✕"
                                    Click="OnClose_Click" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ── Ninja stage: desert scene with chibi ninja ── -->
                <Border Grid.Row="1"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,1"
                        ClipToBounds="True">
                    <Border.Background>
                        <!-- Sky gradient: pale dusty blue → warm cream at horizon -->
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="{StaticResource SkyTopColor}" Offset="0.0" />
                            <GradientStop Color="{StaticResource SkyHorizonColor}" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>

                    <!-- Use Viewbox so the whole scene scales cleanly with the window -->
                    <Viewbox Stretch="Uniform">
                        <!-- Scene canvas: 340 wide × 160 tall, matches stage aspect -->
                        <Canvas Width="340" Height="160">

                            <!-- ── SUN (squircle — rounded square like v1) ── -->
                            <!-- Soft outer glow -->
                            <Rectangle Canvas.Left="240" Canvas.Top="18"
                                       Width="56" Height="56"
                                       RadiusX="14" RadiusY="14"
                                       Fill="{StaticResource SunGlowBrush}"
                                       Opacity="0.35"
                                       IsHitTestVisible="False" />
                            <!-- Invisible enlarged hit target for the sun.
                                 The visible sun is 40x40 but a 56x56 transparent
                                 hit zone gives a more forgiving click target,
                                 especially helpful on touch/high-DPI displays.
                                 Sits BEHIND the visible sun in z-order. -->
                            <Rectangle x:Name="SunHitTarget"
                                       Canvas.Left="240" Canvas.Top="18"
                                       Width="56" Height="56"
                                       Fill="Transparent"
                                       Cursor="Hand"
                                       MouseLeftButtonDown="OnSun_LeftClick"
                                       MouseRightButtonDown="OnSun_RightClick"
                                       ToolTip="Click for a random move • right-click to pick" />
                            <!-- Solid sun -->
                            <Rectangle x:Name="SunDisc"
                                       Canvas.Left="248" Canvas.Top="26"
                                       Width="40" Height="40"
                                       RadiusX="10" RadiusY="10"
                                       Cursor="Hand"
                                       Stroke="#FF7A4A0F"
                                       StrokeThickness="0.8"
                                       MouseLeftButtonDown="OnSun_LeftClick"
                                       MouseRightButtonDown="OnSun_RightClick"
                                       ToolTip="Click for a random move • right-click to pick">
                                <Rectangle.Fill>
                                    <RadialGradientBrush GradientOrigin="0.4,0.4">
                                        <GradientStop Color="#FFFFE08A" Offset="0.0" />
                                        <GradientStop Color="{StaticResource SunColor}" Offset="0.65" />
                                        <GradientStop Color="{StaticResource SunGlowColor}" Offset="1.0" />
                                    </RadialGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>

                            <!-- ── DISTANT MOUNTAIN RANGE (lightest, atmospheric) ── -->
                            <Path Fill="{StaticResource MesaHiBrush}" Opacity="0.55"
                                  Data="M 0,110
                                        L 30,82 50,92 75,72 110,90 140,78 175,95 210,82 245,92 280,80 315,95 340,88
                                        L 340,160 0,160 Z" />

                            <!-- ── MID-RANGE MESAS (medium tone) ── -->
                            <Path Fill="{StaticResource MesaMidBrush}"
                                  Data="M 0,128
                                        L 25,118 25,108 65,108 65,118 90,118
                                        L 130,128
                                        L 175,118 175,105 220,105 220,118 250,128
                                        L 290,118 290,112 320,112 320,118 340,124
                                        L 340,160 0,160 Z" />

                            <!-- ── FOREGROUND DUNES (darkest) ── -->
                            <Path Fill="{StaticResource MesaLoBrush}"
                                  Data="M 0,150
                                        C 40,138 80,148 120,144
                                        C 170,140 210,152 260,146
                                        C 300,142 330,150 340,148
                                        L 340,160 0,160 Z" />

                            <!-- A small cactus silhouette for character -->
                            <Path Fill="{StaticResource MesaLoBrush}" Opacity="0.85"
                                  Data="M 35,148
                                        L 35,138 33,138 33,134 35,134 35,128
                                        L 39,128 39,134 41,134 41,138 39,138 39,142
                                        L 43,142 43,136 45,136 45,144 39,144 39,148 Z" />

                            <!-- ════════════════════════════════════════════════ -->
                            <!-- ════════════ CHIBI NINJA ═══════════════════════ -->
                            <!-- ════════════════════════════════════════════════ -->
                            <!-- NinjaRoot has a transform group for whole-body
                                 movement (translate, rotate, scale). Limb
                                 sub-canvases have their OWN transforms for
                                 rotate-around-shoulder/hip during animations. -->
                            <Canvas x:Name="NinjaRoot" Canvas.Left="135" Canvas.Top="78">
                                <Canvas.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform x:Name="NinjaScale" CenterX="35" CenterY="60" ScaleX="1" ScaleY="1" />
                                        <RotateTransform x:Name="NinjaRotate" CenterX="35" CenterY="60" Angle="0" />
                                        <TranslateTransform x:Name="NinjaTranslate" X="0" Y="0" />
                                    </TransformGroup>
                                </Canvas.RenderTransform>

                                <!-- ── BACK ARM (right arm, drawn first so it's behind) ── -->
                                <!-- CacheMode=BitmapCache: WPF rasterizes this canvas
                                     once and just transforms the bitmap during animation —
                                     huge perf win since strokes/paths normally re-rasterize
                                     every frame. -->
                                <Canvas x:Name="RightArm" Canvas.Left="0" Canvas.Top="0" CacheMode="BitmapCache"
                                        >
                                    <Canvas.RenderTransform>
                                        <RotateTransform x:Name="RightArmRotate" CenterX="54" CenterY="42" Angle="0" />
                                    </Canvas.RenderTransform>
                                    <Path Fill="{StaticResource NinjaBrush}"
                                          Stroke="#FF101010" StrokeThickness="0.6"
                                          StrokeLineJoin="Round"
                                          Data="M 54,42
                                                C 60,44 64,50 64,58
                                                C 64,62 61,64 58,62
                                                L 52,52
                                                C 51,48 52,44 54,42 Z" />
                                    <Ellipse Canvas.Left="55" Canvas.Top="58"
                                             Width="9" Height="9"
                                             Stroke="#FF101010" StrokeThickness="0.5"
                                             Fill="{StaticResource NinjaSkinBrush}" />
                                </Canvas>

                                <!-- ── LEGS ── -->
                                <Canvas x:Name="LeftLeg" Canvas.Left="0" Canvas.Top="0" CacheMode="BitmapCache"
                                        >
                                    <Canvas.RenderTransform>
                                        <RotateTransform x:Name="LeftLegRotate" CenterX="26" CenterY="68" Angle="0" />
                                    </Canvas.RenderTransform>
                                    <Path Fill="{StaticResource NinjaDarkBrush}"
                                          Stroke="#FF101010" StrokeThickness="0.6"
                                          Data="M 22,68 L 22,82 L 30,82 L 30,68 Z" />
                                    <Ellipse Canvas.Left="20" Canvas.Top="80"
                                             Width="14" Height="5"
                                             Stroke="#FF101010" StrokeThickness="0.5"
                                             Fill="{StaticResource NinjaDarkBrush}" />
                                </Canvas>

                                <Canvas x:Name="RightLeg" Canvas.Left="0" Canvas.Top="0" CacheMode="BitmapCache"
                                        >
                                    <Canvas.RenderTransform>
                                        <RotateTransform x:Name="RightLegRotate" CenterX="44" CenterY="68" Angle="0" />
                                    </Canvas.RenderTransform>
                                    <Path Fill="{StaticResource NinjaDarkBrush}"
                                          Stroke="#FF101010" StrokeThickness="0.6"
                                          Data="M 40,68 L 40,82 L 48,82 L 48,68 Z" />
                                    <Ellipse Canvas.Left="38" Canvas.Top="80"
                                             Width="14" Height="5"
                                             Stroke="#FF101010" StrokeThickness="0.5"
                                             Fill="{StaticResource NinjaDarkBrush}" />
                                </Canvas>

                                <!-- ── TORSO ── -->
                                <Path Fill="{StaticResource NinjaBrush}"
                                      Stroke="#FF101010" StrokeThickness="0.6"
                                      StrokeLineJoin="Round"
                                      Data="M 22,38
                                            C 18,38 16,42 16,48
                                            L 16,62
                                            C 16,66 18,68 22,68
                                            L 48,68
                                            C 52,68 54,66 54,62
                                            L 54,48
                                            C 54,42 52,38 48,38 Z" />
                                <!-- Belt sash -->
                                <Rectangle Canvas.Left="16" Canvas.Top="58"
                                           Width="38" Height="4"
                                           Fill="{StaticResource AccentBrush}" />
                                <Path Fill="{StaticResource AccentBrush}"
                                      Stroke="#FF101010" StrokeThickness="0.4"
                                      Data="M 32,62 L 30,68 38,68 36,62 Z" />

                                <!-- ── FRONT ARM (left arm, holds sword, drawn after torso so it's on top) ── -->
                                <Canvas x:Name="LeftArm" Canvas.Left="0" Canvas.Top="0" CacheMode="BitmapCache"
                                        >
                                    <Canvas.RenderTransform>
                                        <RotateTransform x:Name="LeftArmRotate" CenterX="16" CenterY="42" Angle="0" />
                                    </Canvas.RenderTransform>
                                    <Path Fill="{StaticResource NinjaBrush}"
                                          Stroke="#FF101010" StrokeThickness="0.6"
                                          StrokeLineJoin="Round"
                                          Data="M 16,42
                                                C 10,44 6,52 6,60
                                                C 6,64 9,66 12,64
                                                L 18,52
                                                C 19,48 18,44 16,42 Z" />
                                    <Ellipse Canvas.Left="6" Canvas.Top="58"
                                             Width="9" Height="9"
                                             Stroke="#FF101010" StrokeThickness="0.5"
                                             Fill="{StaticResource NinjaSkinBrush}" />

                                    <!-- ── SWORD (rotates with the arm) ── -->
                                    <Path Fill="#FFD8DCE0" Stroke="#FF505860" StrokeThickness="0.6"
                                          Data="M 10,60
                                                L -8,28
                                                L -5,26
                                                L 13,58 Z" />
                                    <Path Fill="#FFFFFFFF" Opacity="0.5"
                                          Data="M -8,28 L -5,26 L -2,30 L -5,32 Z" />
                                    <Rectangle Canvas.Left="6" Canvas.Top="58"
                                               Width="10" Height="2.5"
                                               Fill="#FF1F1207"
                                               Stroke="#FF101010" StrokeThickness="0.4" />
                                    <Rectangle Canvas.Left="9" Canvas.Top="60"
                                               Width="4" Height="6"
                                               Fill="{StaticResource AccentBrush}"
                                               Stroke="#FF101010" StrokeThickness="0.3" />
                                </Canvas>

                                <!-- ════════════════════════════════════════════ -->
                                <!-- ── HEAD (drawn last so it sits on top) ── -->
                                <!-- ════════════════════════════════════════════ -->
                                <Canvas x:Name="Head" Canvas.Left="0" Canvas.Top="0" CacheMode="BitmapCache"
                                        >
                                    <Canvas.RenderTransform>
                                        <RotateTransform x:Name="HeadRotate" CenterX="35" CenterY="32" Angle="0" />
                                    </Canvas.RenderTransform>

                                    <!-- Head silhouette (hood) -->
                                    <Ellipse Canvas.Left="8" Canvas.Top="0"
                                             Width="54" Height="48"
                                             Stroke="#FF101010" StrokeThickness="0.6"
                                             Fill="{StaticResource NinjaBrush}" />

                                    <!-- Hood shadow on lower part -->
                                    <Ellipse Canvas.Left="8" Canvas.Top="14"
                                             Width="54" Height="36"
                                             Fill="{StaticResource NinjaDarkBrush}" />

                                    <!-- Skin patch (face area) -->
                                    <Path Fill="{StaticResource NinjaSkinBrush}"
                                          Data="M 16,24
                                                L 54,24
                                                L 54,34
                                                C 54,38 50,40 46,40
                                                L 24,40
                                                C 20,40 16,38 16,34 Z" />

                                    <!-- ── HEADBAND ── -->
                                    <Path Fill="{StaticResource AccentBrush}"
                                          Stroke="#FF101010" StrokeThickness="0.5"
                                          Data="M 9,18
                                                C 9,17 12,16 16,16
                                                L 54,16
                                                C 58,16 61,17 61,18
                                                L 61,22
                                                C 61,23 58,24 54,24
                                                L 16,24
                                                C 12,24 9,23 9,22 Z" />
                                    <Rectangle Canvas.Left="9" Canvas.Top="22"
                                               Width="52" Height="1.5"
                                               Fill="#FF8B5A0F" Opacity="0.4" />
                                    <Path Fill="{StaticResource AccentBrush}"
                                          Stroke="#FF101010" StrokeThickness="0.4"
                                          Data="M 9,19
                                                L 4,17
                                                L 1,21
                                                L 3,25
                                                L 8,24 Z" />
                                    <!-- Tail 1 -->
                                    <Path Fill="{StaticResource AccentBrush}"
                                          Stroke="#FF101010" StrokeThickness="0.3"
                                          Data="M 4,22
                                                C 0,26 -2,32 0,36
                                                C 1,33 3,30 5,28
                                                C 6,25 5,23 4,22 Z" />
                                    <Path Fill="{StaticResource AccentBrush}" Opacity="0.85"
                                          Stroke="#FF101010" StrokeThickness="0.3"
                                          Data="M 2,24
                                                C -2,28 -4,34 -3,38
                                                C -1,35 1,32 3,29
                                                C 4,27 3,25 2,24 Z" />

                                    <!-- ── EYES ── -->
                                    <Ellipse Canvas.Left="20" Canvas.Top="28"
                                             Width="11" Height="9" Fill="White" />
                                    <Ellipse Canvas.Left="39" Canvas.Top="28"
                                             Width="11" Height="9" Fill="White" />
                                    <Ellipse Canvas.Left="23" Canvas.Top="29"
                                             Width="6" Height="7" Fill="{StaticResource NinjaDarkBrush}" />
                                    <Ellipse Canvas.Left="42" Canvas.Top="29"
                                             Width="6" Height="7" Fill="{StaticResource NinjaDarkBrush}" />
                                    <Ellipse Canvas.Left="26" Canvas.Top="30"
                                             Width="2" Height="2" Fill="White" />
                                    <Ellipse Canvas.Left="45" Canvas.Top="30"
                                             Width="2" Height="2" Fill="White" />

                                    <!-- ── Lower mask covering nose/mouth ── -->
                                    <Path Fill="{StaticResource NinjaDarkBrush}"
                                          Data="M 14,38
                                                C 14,42 18,46 24,46
                                                L 46,46
                                                C 52,46 56,42 56,38
                                                L 56,40
                                                C 56,42 52,44 46,44
                                                L 24,44
                                                C 18,44 14,42 14,40 Z" />
                                </Canvas>

                            </Canvas>

                            <!-- ── FIREBALL (used by Hadouken, hidden by default) ── -->
                            <!-- Lives at the stage canvas level so it can travel
                                 across the whole scene independent of the ninja. -->
                            <Canvas x:Name="FireballRoot"
                                    Canvas.Left="0" Canvas.Top="0"
                                    Opacity="0"
                                    CacheMode="BitmapCache"
                                    >
                                <Canvas.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform x:Name="FireballScale" CenterX="0" CenterY="0" ScaleX="1" ScaleY="1" />
                                        <TranslateTransform x:Name="FireballTranslate" X="0" Y="0" />
                                    </TransformGroup>
                                </Canvas.RenderTransform>

                                <!-- Outer blue chi halo — soft glow -->
                                <Ellipse Canvas.Left="-20" Canvas.Top="-20"
                                         Width="40" Height="40"
                                         Opacity="0.5">
                                    <Ellipse.Fill>
                                        <RadialGradientBrush>
                                            <GradientStop Color="#FFB8E5FF" Offset="0.0" />
                                            <GradientStop Color="#FF2A7CFF" Offset="0.6" />
                                            <GradientStop Color="#001A5CFF" Offset="1.0" />
                                        </RadialGradientBrush>
                                    </Ellipse.Fill>
                                </Ellipse>
                                <!-- Mid blue layer -->
                                <Ellipse Canvas.Left="-13" Canvas.Top="-13"
                                         Width="26" Height="26">
                                    <Ellipse.Fill>
                                        <RadialGradientBrush>
                                            <GradientStop Color="#FFE6F4FF" Offset="0.0" />
                                            <GradientStop Color="#FF6BB4FF" Offset="0.5" />
                                            <GradientStop Color="#FF1E5FE0" Offset="1.0" />
                                        </RadialGradientBrush>
                                    </Ellipse.Fill>
                                </Ellipse>
                                <!-- Bright white-hot core -->
                                <Ellipse Canvas.Left="-6" Canvas.Top="-6"
                                         Width="12" Height="12">
                                    <Ellipse.Fill>
                                        <RadialGradientBrush>
                                            <GradientStop Color="#FFFFFFFF" Offset="0.0" />
                                            <GradientStop Color="#FFD0EBFF" Offset="1.0" />
                                        </RadialGradientBrush>
                                    </Ellipse.Fill>
                                </Ellipse>
                                <!-- Trailing chi wisps behind (blue) -->
                                <Ellipse Canvas.Left="-26" Canvas.Top="-4"
                                         Width="10" Height="8" Opacity="0.65">
                                    <Ellipse.Fill>
                                        <RadialGradientBrush>
                                            <GradientStop Color="#FF80C0FF" Offset="0.0" />
                                            <GradientStop Color="#001E5FE0" Offset="1.0" />
                                        </RadialGradientBrush>
                                    </Ellipse.Fill>
                                </Ellipse>
                                <Ellipse Canvas.Left="-34" Canvas.Top="-3"
                                         Width="8" Height="6" Opacity="0.4">
                                    <Ellipse.Fill>
                                        <RadialGradientBrush>
                                            <GradientStop Color="#FF60AFFF" Offset="0.0" />
                                            <GradientStop Color="#001E5FE0" Offset="1.0" />
                                        </RadialGradientBrush>
                                    </Ellipse.Fill>
                                </Ellipse>
                            </Canvas>

                            <!-- Speech bubble — shouts the move name during animations.
                                 Positioned above-right of the ninja, sharing the
                                 same Canvas coordinate space as the rest of the
                                 scene so it scales together with the Viewbox.
                                 Starts invisible; ShowShout() drives opacity/scale.
                                 IsHitTestVisible=False so it doesn't block clicks
                                 to the sun underneath (this is purely decorative). -->
                            <Canvas x:Name="ShoutBubble"
                                    Canvas.Left="170" Canvas.Top="10"
                                    Opacity="0"
                                    IsHitTestVisible="False">
                                <Canvas.RenderTransform>
                                    <ScaleTransform x:Name="ShoutBubbleScale"
                                                    ScaleX="1" ScaleY="1"
                                                    CenterX="0" CenterY="30" />
                                </Canvas.RenderTransform>

                                <!-- Bubble shape: rounded box with a small tail
                                     pointing down-left toward the ninja. -->
                                <Path Fill="#FFFFFCE6"
                                      Stroke="#FF1B1B1B" StrokeThickness="1.8"
                                      StrokeLineJoin="Round"
                                      Data="M 6,0 L 138,0 Q 146,0 146,8 L 146,30 Q 146,38 138,38 L 24,38 L 14,48 L 18,38 L 6,38 Q -2,38 -2,30 L -2,8 Q -2,0 6,0 Z" />

                                <!-- Move-name text — bold, slightly skewed for yelling feel -->
                                <TextBlock x:Name="ShoutText"
                                           Canvas.Left="6" Canvas.Top="6"
                                           Width="132" Height="26"
                                           Text="HADOUKEN!"
                                           FontFamily="Impact, Arial Black, sans-serif"
                                           FontSize="18"
                                           Foreground="#FF1B1B1B"
                                           TextAlignment="Center"
                                           VerticalAlignment="Center">
                                    <TextBlock.RenderTransform>
                                        <SkewTransform AngleX="-8" />
                                    </TextBlock.RenderTransform>
                                </TextBlock>
                            </Canvas>
                        </Canvas>
                    </Viewbox>
                </Border>

                <!-- v2.4+ two-section item view: Pinned + Recent.
                     A shared search bar above filters whichever section the
                     user is currently focused on. Pinned is collapsible and
                     hidden entirely when empty. Recent occupies the rest. -->
                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />   <!-- Search bar (collapsed by default) -->
                        <RowDefinition Height="Auto" />   <!-- Pinned header (hidden when empty) -->
                        <RowDefinition Height="Auto" />   <!-- Pinned items -->
                        <RowDefinition Height="Auto" />   <!-- Recent header -->
                        <RowDefinition Height="*" />      <!-- Recent items -->
                    </Grid.RowDefinitions>

                    <!-- Search bar — shared by Pinned + Recent. Ctrl+F
                         focuses; Esc closes. Filter is case-insensitive
                         substring match against display text. -->
                    <Border Grid.Row="0"
                            x:Name="SlotSearchBar"
                            Background="{StaticResource PanelBrush}"
                            Padding="6,4"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,0,0,1"
                            Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     x:Name="SlotSearchBox"
                                     FontSize="11"
                                     Padding="6,3"
                                     TextChanged="OnSlotSearch_TextChanged"
                                     KeyDown="OnSlotSearch_KeyDown">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Background" Value="{StaticResource BgBrush}" />
                                        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                                        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
                                        <Setter Property="BorderThickness" Value="1" />
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                            <!-- Type filter — icon toggles, one per content
                                 type, matching the glyphs used elsewhere in
                                 the app. Hover for the name. Click the lit
                                 one again (or ✕ All) to clear. Combines with
                                 the text search. Tag = filter key consumed by
                                 ApplySlotFilter.
                                 Toggles rather than a ComboBox: no
                                 SelectedIndex, so nothing fires during XAML
                                 parse (that was the v2.5.2 startup NRE). -->
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="4,0,0,0">
                                <ToggleButton x:Name="TypeAll"   Tag="All"   Content="All" FontSize="10" Width="30" Height="22" Margin="0,0,2,0" Cursor="Hand" IsChecked="True" Click="OnTypeFilter_Click" ToolTip="All types" />
                                <ToggleButton x:Name="TypeImage" Tag="Image" Content="🖼"  FontSize="11" Width="26" Height="22" Margin="0,0,2,0" Cursor="Hand" Click="OnTypeFilter_Click" ToolTip="Screenshots &amp; images" />
                                <ToggleButton x:Name="TypeUrl"   Tag="Url"   Content="🔗"  FontSize="11" Width="26" Height="22" Margin="0,0,2,0" Cursor="Hand" Click="OnTypeFilter_Click" ToolTip="URLs" />
                                <ToggleButton x:Name="TypeText"  Tag="Text"  Content="📄"  FontSize="11" Width="26" Height="22" Margin="0,0,2,0" Cursor="Hand" Click="OnTypeFilter_Click" ToolTip="Plain text" />
                                <ToggleButton x:Name="TypeHtml"  Tag="Html"  Content="🌐"  FontSize="11" Width="26" Height="22" Margin="0,0,2,0" Cursor="Hand" Click="OnTypeFilter_Click" ToolTip="HTML / rich text" />
                                <ToggleButton x:Name="TypeExcel" Tag="Excel" Content="📊"  FontSize="11" Width="26" Height="22" Margin="0,0,2,0" Cursor="Hand" Click="OnTypeFilter_Click" ToolTip="Excel / spreadsheet" />
                            </StackPanel>
                            <Button Grid.Column="2"
                                    Content="✕"
                                    FontSize="10"
                                    Padding="6,2"
                                    Margin="4,0,0,0"
                                    Cursor="Hand"
                                    Click="OnSlotSearchClose_Click"
                                    ToolTip="Close search (Esc)" />
                        </Grid>
                    </Border>

                    <!-- Pinned section header — hidden entirely when empty -->
                    <Border Grid.Row="1"
                            x:Name="PinnedSectionHeader"
                            Background="{StaticResource PanelBrush}"
                            Padding="8,4,8,2"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,1,0,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding PinnedItems.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock FontSize="10"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource AccentBrush}"
                                   VerticalAlignment="Center">
                            <Run Text="★ PINNED (" />
                            <Run Text="{Binding PinnedItems.Count, Mode=OneWay}" />
                            <Run Text=")" />
                        </TextBlock>
                    </Border>

                    <!-- Pinned items list — same template as Recent (ClipSlot rows) -->
                    <ListBox Grid.Row="2"
                             x:Name="PinnedList"
                             ItemsSource="{Binding PinnedItems}"
                             ItemTemplate="{StaticResource SlotItemTemplate}"
                             Background="{StaticResource BgBrush}"
                             BorderThickness="0"
                             MaxHeight="280"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.Style>
                            <Style TargetType="ListBox">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding PinnedItems.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.Style>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <ContentPresenter />
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>

                    <!-- Recent section header — always visible -->
                    <Border Grid.Row="3"
                            Background="{StaticResource PanelBrush}"
                            Padding="8,4,8,2"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,1,0,0">
                        <TextBlock FontSize="10"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource SubTextBrush}"
                                   VerticalAlignment="Center">
                            <Run Text="⏱ RECENT (" />
                            <Run Text="{Binding RecentItems.Count, Mode=OneWay}" />
                            <Run Text=")" />
                        </TextBlock>
                    </Border>

                    <!-- Recent items list — newest at top; the primary work area -->
                    <ListBox Grid.Row="4"
                             x:Name="SlotList"
                             ItemsSource="{Binding RecentItems}"
                             ItemTemplate="{StaticResource SlotItemTemplate}"
                             Background="{StaticResource BgBrush}"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <ContentPresenter />
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>

                    <!-- First-run empty state for Recent -->
                    <TextBlock Grid.Row="4"
                               IsHitTestVisible="False"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Top"
                               Margin="0,24,0,0"
                               FontSize="11"
                               TextAlignment="Center"
                               Foreground="{StaticResource SubTextBrush}"
                               Text="📋 Copy something to get started.&#10;Captures will appear here.">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding RecentItems.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <!-- Footer -->
                <!-- History overlay panel. Hidden by default. Spans rows 1+2
                     so it covers the ninja stage AND slot list when open,
                     leaving the header drag bar and the footer hint area
                     visible underneath. Click outside or the close button
                     to dismiss. -->
                <Border x:Name="HistoryPanel"
                        Grid.Row="1"
                        Grid.RowSpan="2"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource AccentBrush}"
                        BorderThickness="0,2,0,0"
                        Visibility="Collapsed"
                        Panel.ZIndex="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />   <!-- Header bar -->
                            <RowDefinition Height="Auto" />   <!-- Search row -->
                            <RowDefinition Height="*" />      <!-- List -->
                        </Grid.RowDefinitions>

                        <!-- Header: title + clear all + close -->
                        <Grid Grid.Row="0"
                              Margin="10,8,10,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       VerticalAlignment="Center">
                                <Run Text="📜 History"
                                     FontSize="14"
                                     FontWeight="Bold"
                                     Foreground="{StaticResource TextBrush}" />
                                <Run Text=" — "
                                     Foreground="{StaticResource SubTextBrush}" />
                                <Run Text="{Binding History.Items.Count, Mode=OneWay}"
                                     Foreground="{StaticResource SubTextBrush}" />
                                <Run Text=" items"
                                     Foreground="{StaticResource SubTextBrush}" />
                            </TextBlock>
                            <Button Grid.Column="1"
                                    Content="🗑️ Clear all"
                                    FontSize="10"
                                    Padding="6,2"
                                    Margin="0,0,6,0"
                                    Cursor="Hand"
                                    Click="OnHistoryClearAll_Click"
                                    ToolTip="Remove every item from history (cannot be undone)" />
                            <Button Grid.Column="2"
                                    Content="✕"
                                    FontSize="11"
                                    FontWeight="Bold"
                                    Padding="6,2"
                                    Cursor="Hand"
                                    Click="OnHistoryClose_Click"
                                    ToolTip="Close the history panel" />
                        </Grid>

                        <!-- Search box -->
                        <TextBox Grid.Row="1"
                                 x:Name="HistorySearchBox"
                                 Margin="10,2,10,6"
                                 Padding="6,3"
                                 FontSize="11"
                                 TextChanged="OnHistorySearch_TextChanged">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Background" Value="{StaticResource BgBrush}" />
                                    <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                                    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
                                    <Setter Property="BorderThickness" Value="1" />
                                </Style>
                            </TextBox.Style>
                        </TextBox>

                        <!-- History list -->
                        <ListBox Grid.Row="2"
                                 x:Name="HistoryListBox"
                                 Background="{StaticResource BgBrush}"
                                 BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 MouseDoubleClick="OnHistoryItem_DoubleClick">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="Margin" Value="0,1" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type m:HistoryItem}">
                                    <Border Background="{StaticResource PanelBrush}"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="0,0,0,1"
                                            Padding="8,4"
                                            Cursor="Hand"
                                            ToolTip="Double-click to promote back to slot 1 • Drag to drop into another app • Hover the icon to preview"
                                            MouseEnter="OnHistoryRow_MouseEnter"
                                            MouseLeave="OnHistoryRow_MouseLeave"
                                            PreviewMouseLeftButtonDown="OnHistoryRow_MouseDown"
                                            PreviewMouseMove="OnHistoryRow_MouseMove">
                                        <Border.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Promote back to slot 1"
                                                          Click="OnHistoryItem_Promote" />
                                                <MenuItem Header="Delete from history"
                                                          Click="OnHistoryItem_Delete" />
                                            </ContextMenu>
                                        </Border.ContextMenu>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="36" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <!-- ─ Image thumbnail (image content) ──────────── -->
                                            <Border Grid.Column="0"
                                                    Width="32" Height="32"
                                                    Background="{StaticResource BorderBrush}"
                                                    CornerRadius="2"
                                                    Visibility="{Binding HasImage, Converter={StaticResource BoolToVis}}">
                                                <Grid>
                                                    <Image Source="{Binding ThumbnailSource}"
                                                           Width="32" Height="32"
                                                           Stretch="Uniform"
                                                           RenderOptions.BitmapScalingMode="LowQuality"
                                                           UseLayoutRounding="True"
                                                           SnapsToDevicePixels="True" />
                                                    <Border Visibility="{Binding HasGif, Converter={StaticResource BoolToVis}}"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Bottom"
                                                            Background="#FFE54545"
                                                            CornerRadius="2"
                                                            Padding="2,0"
                                                            Margin="0,0,1,1">
                                                        <TextBlock Text="GIF"
                                                                   FontFamily="Arial Black, Impact, sans-serif"
                                                                   FontSize="7"
                                                                   FontWeight="Bold"
                                                                   Foreground="White" />
                                                    </Border>
                                                </Grid>
                                            </Border>

                                            <!-- ─ Spreadsheet icon ──────────────────────────── -->
                                            <Border Grid.Column="0"
                                                    Width="32" Height="32"
                                                    Background="#FFA8CBA0"
                                                    CornerRadius="2"
                                                    Visibility="{Binding HasSpreadsheet, Converter={StaticResource BoolToVis}}"
                                                    ToolTip="Spreadsheet / table data">
                                                <Viewbox Margin="4">
                                                    <Canvas Width="24" Height="24">
                                                        <Rectangle Canvas.Left="1" Canvas.Top="2"
                                                                   Width="22" Height="20"
                                                                   Stroke="#FF305A2A" StrokeThickness="1.5"
                                                                   Fill="Transparent" RadiusX="1" RadiusY="1" />
                                                        <Rectangle Canvas.Left="1" Canvas.Top="2"
                                                                   Width="22" Height="5"
                                                                   Fill="#FF305A2A" Opacity="0.85" RadiusX="1" RadiusY="1" />
                                                        <Line X1="9" Y1="2" X2="9" Y2="22"
                                                              Stroke="#FF305A2A" StrokeThickness="1" />
                                                        <Line X1="16" Y1="2" X2="16" Y2="22"
                                                              Stroke="#FF305A2A" StrokeThickness="1" />
                                                        <Line X1="1" Y1="12" X2="23" Y2="12"
                                                              Stroke="#FF305A2A" StrokeThickness="1" />
                                                        <Line X1="1" Y1="17" X2="23" Y2="17"
                                                              Stroke="#FF305A2A" StrokeThickness="1" />
                                                    </Canvas>
                                                </Viewbox>
                                            </Border>

                                            <!-- ─ Plain-text icon ───────────────────────────── -->
                                            <Border Grid.Column="0"
                                                    Width="32" Height="32"
                                                    Background="{StaticResource AccentBrush}"
                                                    CornerRadius="2"
                                                    Visibility="{Binding HasPlainText, Converter={StaticResource BoolToVis}}"
                                                    ToolTip="Text">
                                                <Viewbox Margin="5">
                                                    <Canvas Width="22" Height="22">
                                                        <Path Fill="{StaticResource PanelBrush}"
                                                              Stroke="{StaticResource PanelBrush}"
                                                              StrokeThickness="0.6"
                                                              StrokeLineJoin="Round"
                                                              Data="M 3,2 L 14,2 L 20,8 L 20,20 L 3,20 Z" />
                                                        <Path Fill="{StaticResource BgBrush}"
                                                              Stroke="{StaticResource PanelBrush}"
                                                              StrokeThickness="0.5"
                                                              Data="M 14,2 L 20,8 L 14,8 Z" />
                                                        <Line X1="6" Y1="11" X2="17" Y2="11"
                                                              Stroke="{StaticResource AccentBrush}" StrokeThickness="1.4"
                                                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                                        <Line X1="6" Y1="14" X2="17" Y2="14"
                                                              Stroke="{StaticResource AccentBrush}" StrokeThickness="1.4"
                                                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                                        <Line X1="6" Y1="17" X2="13" Y2="17"
                                                              Stroke="{StaticResource AccentBrush}" StrokeThickness="1.4"
                                                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                                    </Canvas>
                                                </Viewbox>
                                            </Border>

                                            <!-- ─ URL / link icon ───────────────────────────── -->
                                            <Border Grid.Column="0"
                                                    Width="32" Height="32"
                                                    Background="#FF99AEB5"
                                                    CornerRadius="2"
                                                    Visibility="{Binding HasUrl, Converter={StaticResource BoolToVis}}"
                                                    ToolTip="Link / URL">
                                                <Viewbox Margin="5">
                                                    <Canvas Width="22" Height="22">
                                                        <Path Stroke="#FF1B3A55" StrokeThickness="2.2"
                                                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                                              Fill="Transparent"
                                                              Data="M 4,10 L 7.5,6.5 A 2.5,2.5 0 0 1 11,6.5 L 11.5,7 A 2.5,2.5 0 0 1 11.5,10.5 L 9.5,12.5" />
                                                        <Path Stroke="#FF1B3A55" StrokeThickness="2.2"
                                                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                                              Fill="Transparent"
                                                              Data="M 18,12 L 14.5,15.5 A 2.5,2.5 0 0 1 11,15.5 L 10.5,15 A 2.5,2.5 0 0 1 10.5,11.5 L 12.5,9.5" />
                                                        <Ellipse Canvas.Left="9.5" Canvas.Top="9.5"
                                                                 Width="3" Height="3" Fill="White" Opacity="0.55" />
                                                    </Canvas>
                                                </Viewbox>
                                            </Border>

                                            <!-- ─ Text content area (label + time + 🔗 badge) ─ -->
                                            <StackPanel Grid.Column="1"
                                                        Margin="6,0,6,0"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="{Binding DisplayText}"
                                                           Foreground="{StaticResource TextBrush}"
                                                           FontSize="11"
                                                           TextTrimming="CharacterEllipsis" />
                                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                    <TextBlock Text="{Binding RelativeTime}"
                                                               Foreground="{StaticResource SubTextBrush}"
                                                               FontSize="9" />
                                                    <Border Visibility="{Binding HasLinks, Converter={StaticResource BoolToVis}}"
                                                            Background="#FF1B3A55"
                                                            CornerRadius="2"
                                                            Padding="3,0"
                                                            Margin="6,0,0,0">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="🔗" Foreground="White" FontSize="8" />
                                                            <TextBlock Text="{Binding LinkCount}"
                                                                       Foreground="White"
                                                                       FontSize="8"
                                                                       FontWeight="Bold"
                                                                       Margin="2,0,0,0" />
                                                        </StackPanel>
                                                    </Border>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- "Empty history" overlay shown when no items -->
                        <TextBlock Grid.Row="2"
                                   Text="📜 History is empty.&#10;&#10;Items rolled out of Recent will appear here."
                                   FontSize="12"
                                   TextAlignment="Center"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource SubTextBrush}"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding History.Items.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Border>

                <!-- Footer area: status text, history toggle, and quick hints -->
                <Border Grid.Row="3"
                        Background="{StaticResource PanelBrush}"
                        Padding="8,6,8,8"
                        CornerRadius="0,0,14,14">
                    <StackPanel>
                        <TextBlock x:Name="StatusLine"
                                   Text="{Binding StatusText}"
                                   Style="{StaticResource HintTextStyle}"
                                   Margin="0,0,0,4"
                                   TextWrapping="Wrap" />
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Click item     Load to clipboard"
                                       Style="{StaticResource HintTextStyle}" />
                            <!-- History toggle button. Shows "📜 History (N)"
                                 where N is the current history count. Clicking
                                 opens the history panel as an overlay over
                                 the ninja stage + item lists. -->
                            <Button Grid.Column="1"
                                    x:Name="HistoryToggleBtn"
                                    Click="OnHistoryToggle_Click"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Padding="6,2"
                                    Foreground="{StaticResource AccentBrush}"
                                    FontSize="10"
                                    FontWeight="Bold"
                                    ToolTip="View / search items that have rolled out of the Recent list">
                                <TextBlock>
                                    <Run Text="📜 History (" />
                                    <Run Text="{Binding History.Items.Count, Mode=OneWay, FallbackValue=0}" />
                                    <Run Text=")" />
                                </TextBlock>
                            </Button>
                        </Grid>
                        <TextBlock Text="Then Ctrl+V    Paste in target app"
                                   Style="{StaticResource HintTextStyle}" />
                        <TextBlock Text="Drag item      Reorder / pin / unpin"
                                   Style="{StaticResource HintTextStyle}" />
                        <TextBlock Text="Right-click    Pin / Edit / Move / Remove"
                                   Style="{StaticResource HintTextStyle}" />
                        <TextBlock Text="Ctrl+Shift+N   Show / hide window"
                                   Style="{StaticResource HintTextStyle}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
